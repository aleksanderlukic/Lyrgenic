// Lyrgenic – Prisma schema
// Datasource + client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js adapter tables ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────

enum Plan {
  free
  pro
  creator
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?   // null for OAuth-only accounts
  plan             Plan      @default(free)
  stripeCustomerId String?   @unique
  stripeSubId      String?
  freeUsedToday    Int       @default(0)
  freeResetAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  projects       Project[]
  generationLogs GenerationLog[]
}

// ─── Project ──────────────────────────────────────────────────────────

enum SourceType {
  upload
  youtube
}

model Project {
  id               String     @id @default(cuid())
  userId           String
  name             String
  sourceType       SourceType
  youtubeUrl       String?
  audioOriginalKey String?    // S3 key
  audioMime        String?
  durationSeconds  Float?
  bpm              Float?
  analysisJson     Json?      // AudioAnalysis object
  // Preferences
  genre            String?
  vibe             String?
  language         String     @default("English")
  isExplicit       Boolean    @default(false)
  topic            String?    @db.Text
  inspoArtist      String?
  inspoSong        String?
  status           String     @default("created") // created | analyzing | ready | generating | done | error
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lyricsVersions  LyricsVersion[]
  generationLogs  GenerationLog[]
}

// ─── LyricsVersion ────────────────────────────────────────────────────

enum VersionSource {
  llm
  user
}

model LyricsVersion {
  id               String        @id @default(cuid())
  projectId        String
  versionNumber    Int
  source           VersionSource
  title            String
  songBrief        String        @db.Text
  structureJson    Json          // Array of { name, startSec, endSec }
  lyricsJson       Json          // Array of { section, lines:[{timeSec, text}] }
  performanceNotes String?       @db.Text
  createdAt        DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── GenerationLog ────────────────────────────────────────────────────

enum LogType {
  analysis
  lyrics
  section_regen
  preview
}

model GenerationLog {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  type      LogType
  tokens    Int?
  costUsd   Float?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
